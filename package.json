{
	"name": "obsidian-crate",
	"version": "1.0.0",
	"description": "Crate plugin - Sync your vault to Cloudflare R2",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"build:worker": "node scripts/build-worker.mjs",
		"preview:pwa": "node scripts/pwa-preview.mjs",
		"test:pwa-preview": "node scripts/pwa-smoke-test.mjs",
		"dev": "npm run build:worker && vite build --watch --mode development",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"build": "npm run build:worker && tsc -noEmit -skipLibCheck && vite build",
		"size-check": "node scripts/check-bundle-size.mjs",
		"deploy": "node scripts/deploy.mjs",
		"deploy:configure": "node scripts/deploy.mjs --configure",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"check": "npm run lint && npm run typecheck && npm test"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@codemirror/state": "^6.5.0",
		"@codemirror/view": "^6.38.6",
		"@codemirror/language": "^6.11.3",
		"@eslint/js": "9.30.1",
		"@preact/preset-vite": "^2.10.2",
		"@rollup/plugin-replace": "^6.0.2",
		"@tailwindcss/postcss": "^4.1.17",
		"@types/node": "^22.19.15",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.2.3",
		"autoprefixer": "^10.4.22",
		"esbuild": "^0.27.4",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"postcss": "^8.5.6",
		"preact": "^10.27.2",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"sass": "^1.89.0",
		"tailwindcss": "^4.1.17",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vite": "^7.2.2",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@heroui/react": "^2.8.5",
		"@internationalized/date": "^3.8.2",
		"chrono-node": "^2.9.0",
		"classnames": "^2.5.1",
		"date-fns": "^4.1.0",
		"framer-motion": "^12.23.24",
		"lucide-react": "^0.562.0",
		"obsidian": "latest",
		"qrcode-generator": "^2.0.4",
		"web-push-browser": "^1.4.2",
		"zustand": "^5.0.6"
	}
}
