{
	"name": "@obsidian-crate/cli",
	"version": "1.0.0",
	"description": "CLI tool to set up Cloudflare infrastructure for Obsidian Crate",
	"bin": {
		"crate": "./dist/index.js"
	},
	"scripts": {
		"build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=cjs --banner:js=\"#!/usr/bin/env node\" --external:open",
		"dev": "npm run build && node dist/index.js"
	},
	"keywords": [
		"obsidian",
		"cloudflare",
		"sync",
		"cli"
	],
	"license": "0-BSD",
	"dependencies": {
		"commander": "^12.1.0",
		"inquirer": "^9.2.23",
		"open": "^10.1.0"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"esbuild": "^0.25.5",
		"typescript": "^5.8.3"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
